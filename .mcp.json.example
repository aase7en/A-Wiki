{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/REPLACE/WITH/YOUR/REPO/PATH"
      ],
      "env": {},
      "disabled": false,
      "autoApprove": []
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": ""
      },
      "disabled": false,
      "autoApprove": []
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {},
      "disabled": false,
      "autoApprove": []
    },
    "awiki": {
      "command": "REPLACE_python3_or_python",
      "args": ["scripts/mcp-wiki-server.py"],
      "env": {},
      "disabled": false,
      "autoApprove": [
        "wiki_search",
        "wiki_semantic_search",
        "wiki_get_page",
        "wiki_graph_neighbors"
      ]
    },
    "gitnexus": {
      "command": "npx",
      "args": ["-y", "gitnexus", "mcp"],
      "env": {},
      "disabled": true,
      "autoApprove": ["query", "context", "impact", "detect_changes"]
    }
  }
}
