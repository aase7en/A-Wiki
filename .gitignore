# A-Wiki — Hybrid .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.env

# AI-generated / cache
.claude/lock.txt
.codex/lock.txt
.gemini/lock.txt
wiki-index.db
wiki-graph.json
.wiki-index.db
.wiki-graph.json

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.idea/
.vscode/
*.code-workspace

# Node (ECC tools)
node_modules/
npm-debug.log*

# Build / temp
build/
dist/
*.egg-info/
*.egg

# Test
test-zone/

# Logs
*.log
logs/

# Symlinks (git should ignore these)
.codex/hooks/
.gemini/hooks/

# Large files (should be in GDrive A-Wiki-Data not in repo)
raw/pharmacy/*.json
raw/pharmacy/*.csv
*.db
*.sqlite
*.sqlite3

# Obsidian config (user-local)
.obsidian/workspace.json
.obsidian/workspace

# Scripts override (user-local)
scripts/.zshrc