# ============================================================
# A-Wiki .gitignore — 2026-05-24
# ============================================================
# กฎเหล็ก: ห้ามมีไฟล์ .env / secret / credential ใน git
# ============================================================

# --- Environment & Secrets ---
.env
.env.*
!.env.example
*.key
*.pem
*.crt
*.cert
*credential*
*secret*
*password*
*token*
# แต่ skill token-optimization จำเป็นต้อง track
!skills/claude-code/token-optimization/
*oauth*
*jwt*
*secrets*

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-workspace

# --- Obsidian (full dir — contains plugin configs + secrets) ---
.obsidian/
!.obsidian/git.json

# --- Node / JS ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/
*.tsbuildinfo
.next/
.cache/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.whl

# --- Go ---
vendor/
*.test
*.out

# --- Git / SCM ---
*.orig
*.patch
.git-rewrite/

# --- Build / Output ---
dist/
build/
out/
target/
*.d.ts

# --- Logs ---
*.log
logs/

# --- Database (local clones) ---
*.db
*.sqlite
*.sqlite3

# --- Wiki local data ---
data/
.tmp/
temp/

# raw/ is a symlink to Google Drive (A-Wiki-Data)
raw/

# --- Archive / Downloads ---
*.zip
*.tar.gz
*.rar
*.7z
*.iso

# --- Script outputs ---
out/
output/
results/

# --- Docker (if used) ---
.docker/
docker-compose.override.yml

# --- Terraform ---
*.tfstate
*.tfstate.backup
.terraform/

# --- Agent / AI configs with secrets ---
.claude*
.codex*
.gemini*
!.clinerules
!.mcp.json