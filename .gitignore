# ============================================================
# A-Wiki .gitignore — 2026-05-24
# ============================================================
# กฎเหล็ก: ห้ามมีไฟล์ .env / secret / credential ใน git
# ============================================================

# --- Environment & Secrets ---
.env
.env.*
!.env.example
*.key
*.pem
*.crt
*.cert
*credential*
*secret*
*password*
*token*
# แต่ skill token-optimization จำเป็นต้อง track
!skills/claude-code/token-optimization/
*oauth*
*jwt*
*secrets*
!scripts/lib/drive_secrets.py
!scripts/hooks/check_secret_leak.py

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-workspace

# --- Obsidian (full dir — contains plugin configs + secrets) ---
.obsidian/
!.obsidian/git.json

# --- Node / JS ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/
*.tsbuildinfo
.next/
.cache/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.venv-*/
dist/
build/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.whl

# --- Go ---
vendor/
*.test
*.out

# --- Git / SCM ---
*.orig
*.patch
.git-rewrite/

# --- Build / Output ---
dist/
build/
out/
target/
*.d.ts

# --- Logs ---
*.log
logs/

# --- Database (local clones) ---
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# --- Wiki local data ---
data/
.tmp/
temp/
wiki/context/model-roster.conf.bak

# raw is a symlink (Mac) or junction (Windows) to Google Drive A-Wiki-Data
# Each machine manages its own local link — never tracked in git
raw
raw/

# drive/ — personal data storage symlink (per-user, created by setup-drive-link.sh)
# Each user points this to their own Google Drive / NAS / local storage
# Run: bash scripts/setup-drive-link.sh  to configure
drive
.drive-path

# --- Personal / per-user artifacts (untracked since v2026.05.0 for public-clone safety) ---
# Session journals, NotebookLM exports, and other operational logs belong on
# the user's machine, not in the public repo. See SECURITY.md.
personal/
drive/personal/

# --- Personal scripts (symlinks → drive/personal-tools/ — created by setup-local.sh)
# Actual files live in Google Drive; git tracks only the symlink placeholder (not contents).
# Run: bash scripts/setup-local.sh  to create symlinks on a new machine.
scripts/userscripts/
scripts/telegram-bot/
scripts/personal/

log.md
session-memory.md
wiki/context/session-memory.md
handoff.md
goals.md
!handoff.md.example
!goals.md.example
inw-wiki-critique.md
exports/notebooklm/
core-knowledge/exports/
*.local.md
.A-Wiki-config

# --- Archive / Downloads ---
*.zip
*.tar.gz
*.rar
*.7z
*.iso

# --- Script outputs ---
out/
output/
results/

# --- Docker (if used) ---
.docker/
docker-compose.override.yml

# --- Terraform ---
*.tfstate
*.tfstate.backup
.terraform/

# --- Agent / AI configs with secrets ---
.claude*
.codex*
.gemini*
!.clinerules
# .mcp.json is machine-specific (repo paths differ per machine) — use .mcp.json.example
.mcp.json

# --- GitNexus (code-graph cache, per-machine, can be large) ---
# See: wiki/entities/ai-tools/gitnexus.md
.gitnexus/

# --- Productivity plugin (personal task list + working memory; Iron Law #6) ---
# Dashboard lives in exports/html/ (already ignored). Keep personal data out of git.
/TASKS.md
/memory/
