# ============================================================
# A-Wiki .gitignore — 2026-05-24
# ============================================================
# กฎเหล็ก: ห้ามมีไฟล์ .env / secret / credential ใน git
# ============================================================

# --- Environment & Secrets ---
.env
.env.*
!.env.example
*.key
*.pem
*.crt
*.cert
*credential*
*secret*
*password*
*token*
# แต่ skill token-optimization จำเป็นต้อง track
!skills/claude-code/token-optimization/
*oauth*
*jwt*
*secrets*
!scripts/lib/drive_secrets.py
!scripts/hooks/check_secret_leak.py
# Essential tracked scripts caught by the name globs above (no secrets inside):
!scripts/hermes/sync-secrets-from-drive.sh
!scripts/hermes/sync-secrets-to-drive.sh
!scripts/hooks/check_token_waste.py
!scripts/set-admin-password.py
# Registered skills whose names contain "token" (caught by *token*):
!skills/ecosystem/evm-token-decimals/
!skills/ecosystem/token-budget-advisor/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-workspace

# --- Obsidian (full dir — contains plugin configs + secrets) ---
.obsidian/
!.obsidian/git.json

# --- Node / JS ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/
*.tsbuildinfo
.next/
.cache/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.venv-*/
dist/
build/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.whl

# --- Go ---
vendor/
*.test
*.out

# --- Git / SCM ---
*.orig
*.patch
.git-rewrite/

# --- Build / Output ---
dist/
build/
out/
target/
*.d.ts
# Exception: the /build Telegram command-skill lives under skills/awiki/build/
# and must NOT be ignored. The global `build/` rule above matches its path.
!skills/awiki/build/
!skills/awiki/build/**

# --- Logs ---
*.log
logs/

# --- Database (local clones) ---
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# --- Wiki local data ---
data/
.tmp/
temp/
.playwright-mcp/
wiki/context/model-roster.conf.bak

# --- Skill registry drafts (bootstrap output, never committed) ---
skills-registry.draft.json

# --- Per-agent local state (machine-local; only public configs tracked) ---
# Agent runtime state (history, cache, local settings) belongs on the machine,
# not in the public repo. See Storage Decision Rule in AGENTS.md.
.zcode/
.hermes/
.kilo/plans/
.kilo/worktrees/
.kilo/agent-manager.json
# Root-anchored: unanchored ".agents/" also swallowed vendor-internal
# .agents/ dirs inside skills/_upstream/ecc (83 tracked files flagged as
# escaped-ignored). Vendor snapshots are tracked by design.
/.agents/*
# Exception: react-doctor is a public bootstrap skill (INSTALL_REACT_DOCTOR=1),
# tracked intentionally — not machine-local state. (Dir-level re-include
# chain required: a child negation is dead if its parent dir stays excluded.)
!/.agents/skills/
/.agents/skills/*
!/.agents/skills/react-doctor/
# .gemini/settings.json is tracked by design (public skill config);
# only ignore local overrides.
.gemini/settings.local.json

# raw is a symlink (Mac) or junction (Windows) to Google Drive A-Wiki-Data
# Each machine manages its own local link — never tracked in git
raw
raw/

# drive/ — personal data storage symlink (per-user, created by setup-drive-link.sh)
# Each user points this to their own Google Drive / NAS / local storage
# Run: bash scripts/setup-drive-link.sh  to configure
drive
.drive-path

# --- USA-1 §4: per-agent Drive isolation (.~<agent>/ on A-Wiki-Data) ---
# Agent-specific state (sessions, worktrees, memory, hooks-state, large-artifacts)
# lives on Drive, never in the repo. Matches .~<agent> dirs at repo root
# (accidental) and under drive/. Run: bash scripts/setup-agent-drive.sh
.\~
drive/.~*
.~*/

# --- Real pharmacy business data — lives in drive/pharmacy/ only (Iron Law #6) ---
# Delivery invoices, order history, verified-search items, and exports are real
# business records, not wiki knowledge. Scripts resolve them via
# scripts/drive_path.py::get_pharmacy_dir(). Keep these ignored even if a stale
# script writes back into wiki/entities/pharmacy/ by mistake.
wiki/entities/pharmacy/deliveries/
wiki/entities/pharmacy/order-history.json
wiki/entities/pharmacy/alternative-source-items.json
wiki/entities/pharmacy/exports/

# --- Personal / per-user artifacts (untracked since v2026.05.0 for public-clone safety) ---
# Session journals, NotebookLM exports, and other operational logs belong on
# the user's machine, not in the public repo. See SECURITY.md.
personal/
drive/personal/

# --- Personal scripts (symlinks → drive/personal-tools/ — created by setup-local.sh)
# Actual files live in Google Drive; git tracks only the symlink placeholder (not contents).
# Run: bash scripts/setup-local.sh  to create symlinks on a new machine.
scripts/userscripts/
scripts/telegram-bot/
scripts/personal/

log.md
session-memory.md
wiki/context/session-memory.md
wiki/context/session-memory-*.md
wiki/context/session-summary-*.md
!wiki/context/session-memory.md.example
handoff.md
goals.md
!handoff.md.example
!goals.md.example
inw-wiki-critique.md
exports/notebooklm/*
!exports/notebooklm/README.md
*.local.md
.A-Wiki-config

# --- docs/handoff/ — cross-agent handoff notes (local/private, may contain
# machine paths + in-progress task context; see docs/protocols/cross-agent-plan-handoff.md)
docs/handoff/

# --- .local/ — machine-local personal data (profile.md, session-memory.md) ---
.local/

# --- Archive / Downloads ---
*.zip
*.tar.gz
*.rar
*.7z
*.iso

# --- Script outputs ---
out/
output/
results/

# --- Docker (if used) ---
.docker/
docker-compose.override.yml

# --- Terraform ---
*.tfstate
*.tfstate.backup
.terraform/

# --- Agent / AI configs with secrets ---
.claude*
.gemini*
# Shared-by-design pieces under those globs (cross-device sync Layer 1):
!.claude/
.claude/*
!.claude/hooks/
!.claude/agents/
!.claude/settings.json
!.claude-plugin/
!.gemini/
.gemini/*
!.gemini/settings.json

# .clinerules/ — directory with tracked rules.md + machine-local hooks/
.clinerules/hooks/
.clinerules/skills/
.clinerules/workflows/
!.clinerules/rules.md
# .codex: ignore machine-specific pieces, track public-safe templates
# (git requires parent dir NOT ignored for nested negation to work)
.codex/hooks/
.codex/agents/
!.codex/agents/skeptical-reviewer.toml
.codex/*.sh
.codex/*.lock
# .mcp.json is machine-specific (repo paths differ per machine) — use .mcp.json.example
.mcp.json

# --- GitNexus (code-graph cache, per-machine, can be large) ---
# See: wiki/entities/ai-tools/gitnexus.md
.gitnexus/

# --- Productivity plugin (personal task list + working memory; Iron Law #6) ---
# Dashboard lives in exports/html/ (already ignored). Keep personal data out of git.
/TASKS.md
/memory/

# --- Layer 2: Hermes Context (no secrets) ---
# Sync scripts/hermes/.hermes/config.yaml + SOUL.md + memory/ + sessions/
# But ignore all .env files and secrets
scripts/hermes/.hermes/.env
scripts/hermes/.hermes/.env.local
scripts/hermes/.hermes/.env.*.local
scripts/hermes/.hermes/auth.json
