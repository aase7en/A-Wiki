# A-Wiki Environment Variables
# Copy to .env (gitignored) and fill in your keys
#
# Minimum required: at least one API key
# Recommended: GEMINI_API_KEY (free tier, 1500 req/day) + OPENROUTER_API_KEY

# ─── Core API Keys ─────────────────────────────────────────────────────────────
# Google Gemini — Free tier (60 req/min, 1500 req/day)
# Get: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaYOUR_GEMINI_KEY_HERE

# OpenRouter — Pays-as-you-go, unlocks 300+ models including free tiers
# Get: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY_HERE

# DeepSeek — Direct API (cheap for deepseek-reasoner)
# Get: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-YOUR_DEEPSEEK_KEY_HERE

# Groq — Free tier with high rate limits (Llama, Mixtral)
# Get: https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE

# Anthropic — Claude API (used by delegate.sh as paid fallback)
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY_HERE

# ─── Sync & Cross-Device ───────────────────────────────────────────────────────
# Device identifier for cross-device sync (default: hostname)
# Uncomment and set a custom name:
# WIKI_DEVICE_NAME=macbook-pro

# ─── Hook Configuration (optional) ─────────────────────────────────────────────
# Comma-separated hook names to skip
# HOOK_SKIP=check_apikey,check_secret_leak

# Hook timeout in seconds (default: 5)
# HOOK_TIMEOUT=10

# ─── Delegate Configuration (optional) ─────────────────────────────────────────
# Timeout per model call in seconds (default: 60)
# DELEGATE_TIMEOUT=90

# Custom model roster (comma-separated OpenRouter model IDs)
# TIER1_PRIMARY=google/gemini-2.5-flash:free
# RACE_MODELS=google/gemini-2.5-flash:free deepseek/deepseek-chat-v3-0324:free qwen/qwen3-235b-a22b:free