{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "A-Wiki Agent Config Schema",
  "type": "object",
  "required": [
    "version",
    "agent_types"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "agent_types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "role",
          "default_effort"
        ],
        "properties": {
          "type": {
            "type": "string",
            "pattern": "^[a-z][a-z-]*$"
          },
          "role": {
            "type": "string"
          },
          "default_effort": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "icon": {
            "type": "string",
            "maxLength": 2
          },
          "strength": {
            "type": "string",
            "enum": [
              "reasoning",
              "coding",
              "speed"
            ]
          }
        }
      }
    },
    "effort_scale": {
      "type": "object"
    }
  }
}