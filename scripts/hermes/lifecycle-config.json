{
  "version": "1.0",
  "description": "Configures Hermes to orchestrate A-Wiki lifecycle skills across all agents",
  "phases": {
    "define": {
      "required_before": "plan",
      "skills": ["spec-driven-development"],
      "a_wiki_skills": ["grill-me", "brainstorm-before-build"]
    },
    "plan": {
      "required_before": "build",
      "skills": ["planning-and-task-breakdown"]
    },
    "build": {
      "required_before": "verify",
      "skills": [
        "incremental-implementation",
        "test-driven-development",
        "doubt-driven-development",
        "source-driven-development",
        "frontend-ui-engineering",
        "api-and-interface-design",
        "context-engineering"
      ]
    },
    "verify": {
      "required_before": "review",
      "skills": ["browser-testing-with-devtools"],
      "a_wiki_skills": ["debug-mantra"]
    },
    "review": {
      "required_before": "ship",
      "skills": ["code-simplification", "security-and-hardening", "performance-optimization"],
      "a_wiki_skills": ["scrutinize"]
    },
    "ship": {
      "required_before": null,
      "skills": [
        "git-workflow-and-versioning",
        "ci-cd-and-automation",
        "deprecation-and-migration",
        "documentation-and-adrs",
        "observability-and-instrumentation",
        "shipping-and-launch"
      ],
      "a_wiki_skills": ["post-mortem"]
    }
  },
  "personas": {
    "available": [
      "code-reviewer",
      "test-engineer",
      "security-auditor",
      "web-performance-auditor"
    ],
    "parallel_fan_out": ["code-reviewer", "test-engineer", "security-auditor"],
    "merge_on": ["critical", "important"],
    "rule": "personas_do_not_invoke_personas",
    "platform_notes": {
      "claude_code": "Subagents auto-discovered from agents/ directory. Agent Teams available with CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1.",
      "kilo": "Load persona via skill tool or reference agents/<name>.md",
      "codex": "AGENTS.md intent mapping defines persona routing",
      "gemini_cli": ".gemini/agents/ directory for discovery"
    }
  },
  "domain_routing": {
    "_description": "SO2 — when --domain <d> is passed to persona-orchestrator.py, use these domain-specific review personas/subagents instead of the generic parallel_fan_out. Hermes is SEQUENTIAL-only (no parallel fan-out), so 'fan-out' here means 'which personas run in the sequential pass'. Unknown domains fall back to personas.parallel_fan_out.",
    "medical": {
      "review_personas": ["medical-safety-checker"],
      "verify_skills": ["healthcare-phi-compliance"]
    },
    "finance": {
      "review_personas": ["finance-debater"],
      "build_subagents": ["finance-analyst"]
    },
    "code": {
      "review_personas": ["code-reviewer", "security-auditor"]
    },
    "engineering": {
      "review_personas": ["code-architect", "test-engineer-agent"]
    },
    "ai-ops": {
      "review_personas": ["cost-auditor"]
    },
    "webapp": {
      "review_personas": ["ui-ux-reviewer", "frontend-architect"]
    },
    "business": {
      "review_personas": ["realestate-tax-advisor"]
    },
    "productivity": {
      "review_personas": ["workflow-simplifier"]
    },
    "thai": {
      "review_personas": ["language-tutor"]
    }
  },
  "shortcut_blocklist": [
    {
      "pattern": "implement_without_spec",
      "message": "No code without failing test (Iron Law #1). No implementation without spec for non-trivial changes."
    },
    {
      "pattern": "skip_review_before_ship",
      "message": "Review gate required before SHIP phase. Run /review or parallel fan-out."
    },
    {
      "pattern": "skip_test_before_implementation",
      "message": "Test-Driven Development: write failing test first, then implement."
    },
    {
      "pattern": "dont_document_decision",
      "message": "Architectural decisions require an ADR. Document why before committing."
    }
  ],
  "lifecycle_routing": {
    "skill_directory": "skills/engineering-lifecycle",
    "meta_skill": "skills/engineering-lifecycle/awiki-lifecycle-router/SKILL.md",
    "reference_directory": "references",
    "agent_directory": "agents"
  }
}
