[Unit]
Description=A-Wiki brain sync into Hermes container (host pull + container FF + rescan)
Wants=network-online.target docker.service
After=network-online.target docker.service

[Service]
Type=oneshot
User=@USER@
WorkingDirectory=@HOME@/A-Wiki
ExecStart=/bin/bash @HOME@/A-Wiki/scripts/hermes/auto-sync-from-git.sh
# sync exit 2 = manual conflict parked in stash — visible in journalctl
SuccessExitStatus=0
