{
  "agent": {
    "name": "Gemini Wiki Agent",
    "description": "Gemini CLI agent for A-Wiki ecosystem",
    "skills": {
      "claude_code": "../skills/claude-code",
      "claude_thai": "../skills/claude-thai",
      "ecosystem": "../skills/ecosystem"
    },
    "hooks": "../.claude/hooks",
    "scripts": {
      "wiki": "../scripts/wiki",
      "swarm": "../scripts/swarm",
      "ecosystem": "../scripts/ecosystem"
    }
  },
  "context": {
    "fileName": ["AGENTS.md", "GEMINI.md"]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "name": "a-wiki-session-start",
            "type": "command",
            "command": "python3 scripts/hooks/session_start.py",
            "timeout": 60000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "a-wiki-hooks-runner",
            "type": "command",
            "command": "python3 scripts/hooks_runner.py",
            "timeout": 60000
          }
        ]
      }
    ]
  },
  "version": "1.0.0"
}
